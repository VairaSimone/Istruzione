# ═══════════════════════════════════════════════════════════════════════════
#  FRONTEND — VARIABILI D'AMBIENTE (Vite)
#
#      cp frontend/.env.example frontend/.env
#
#  ⚠️  Tutto ciò che comincia con VITE_ finisce nel BUNDLE ed è pubblico.
#      Non metterci mai segreti: qui vanno solo valori che l'utente potrebbe
#      comunque leggere dal browser.
#
#  Nota: quasi nulla di ciò che si vede a schermo passa da qui. Nome, logo,
#  colori e sezioni attive della scuola arrivano a runtime da `GET /api/config`,
#  perché la STESSA build serve tutte le scuole. Queste variabili configurano il
#  client, non il branding.
# ═══════════════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────────────
#  API
# ───────────────────────────────────────────────────────────────────────────
 
# URL base dell'API backend (Express), comprensivo di /api.
VITE_API_BASE_URL=http://localhost:3000/api


# ───────────────────────────────────────────────────────────────────────────
#  IDENTITÀ
# ───────────────────────────────────────────────────────────────────────────

# ULTIMO fallback del nome mostrato, usato solo se `GET /api/config` non
# risponde e non c'è né nome di scuola né nome di piattaforma. Deve restare
# NEUTRO rispetto alla materia: la piattaforma è generica.
VITE_APP_NAME=Piattaforma Didattica


# ───────────────────────────────────────────────────────────────────────────
#  TENANT (scuola)
# ───────────────────────────────────────────────────────────────────────────

# Slug della scuola fissato IN FASE DI BUILD: la build è dedicata a una sola
# scuola e il tenant non è più cambiabile (il selettore si nasconde, `?scuola=`
# viene ignorato). Lasciare VUOTO per un deploy multi-scuola, dove il tenant si
# risolve da dominio personalizzato, `?scuola=<slug>` o scuola predefinita.
VITE_SCUOLA_SLUG=


# ───────────────────────────────────────────────────────────────────────────
#  LIMITI DI UPLOAD
#
#  ⚠️  DUPLICATI dal backend (UPLOAD_MAX_*). Servono solo a mostrare l'errore
#      prima di far caricare un file che verrebbe comunque respinto: il limite
#      VERO è quello del backend, sempre.
#
#      Non c'è alcuna sincronizzazione automatica: se divergono, l'utente scopre
#      il limite reale con un 413 dopo aver caricato mezzo gigabyte. Vanno tenuti
#      allineati a mano, e cambiati in coppia.
# ───────────────────────────────────────────────────────────────────────────

# Deve combaciare con UPLOAD_MAX_VIDEO_MB del backend (default backend: 1024).
VITE_UPLOAD_MAX_VIDEO_MB=1024

# Deve combaciare con UPLOAD_MAX_IMMAGINE_MB del backend (default backend: 10).
VITE_UPLOAD_MAX_IMMAGINE_MB=10

# Deve combaciare con UPLOAD_MAX_DOCUMENTO_MB del backend (default backend: 100).
VITE_UPLOAD_MAX_DOCUMENTO_MB=100
