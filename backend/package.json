{
  "name": "piattaforma-didattica-backend",
  "version": "2.0.0",
  "description": "Backend Node.js/Express/Sequelize per una piattaforma didattica generica e multi-scuola (multi-tenant).",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "node src/database/umzug.js up",
    "db:migrate:down": "node src/database/umzug.js down",
    "db:sync": "node src/database/migrate.js",
    "seed:admin": "node src/database/seedAdmin.js",
    "seed:scuola": "node src/database/seedScuola.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "i18next": "^26.3.1",
    "i18next-fs-backend": "^2.6.6",
    "i18next-http-middleware": "^3.9.7",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "mysql2": "^3.10.1",
    "nodemailer": "^9.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "sequelize": "^6.37.3",
    "umzug": "^3.8.3",
    "uuid": "^10.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "nodemonConfig": {
    "ignore": [
      "uploads/**",
      "logs/**"
    ]
  }
}
