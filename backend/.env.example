# ═══════════════════════════════════════════════════════════════════════════
#  BACKEND — VARIABILI D'AMBIENTE
#
#  Copia questo file in `backend/.env` e compila almeno la sezione
#  «OBBLIGATORIE». Tutto il resto ha un default sensato ed è opzionale.
#
#      cp backend/.env.example backend/.env
#
#  Convenzioni:
#    • un valore VUOTO equivale a «non impostato» (si applica il default);
#    • i booleani si scrivono `true` / `false` (qualunque altro valore è false);
#    • `.env` è già in .gitignore: NON committarlo mai.
#
#  Provisioning di un'installazione nuova:
#      npm install
#      npm run db:migrate     # crea lo schema (unico sistema, in ogni ambiente)
#      npm run seed:scuola    # prima scuola (tenant)
#      npm run seed:admin     # primo amministratore
#      npm start
# ═══════════════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────────────
#  OBBLIGATORIE — senza queste il server non parte o è inutilizzabile
# ───────────────────────────────────────────────────────────────────────────

# Database MySQL 8. Nessun default: vanno impostate.
DB_NAME=istruzione
DB_USER=istruzione
DB_PASSWORD=

# Segreti JWT. Il controllo è FAIL-FAST all'avvio (cfr. config/jwt.js):
# minimo 32 caratteri e i due segreti DEVONO essere diversi tra loro.
# Generane uno con:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=


# ───────────────────────────────────────────────────────────────────────────
#  CORE
# ───────────────────────────────────────────────────────────────────────────

# `production` | `development`. In development lo stack trace finisce nelle
# risposte di errore: non usarlo mai su un'istanza pubblica.
NODE_ENV=development

# Porta HTTP del server. Default: 3000
PORT=3000

# Verbosità dei log winston: error | warn | info | http | debug. Default: info
LOG_LEVEL=info

# Compressione HTTP (gzip). Attivala SOLO se Node è esposto direttamente a
# Internet: dietro Nginx/Caddy/Cloudflare la compressione è già fatta a monte.
# Default: false
COMPRESSIONE_HTTP=false


# ───────────────────────────────────────────────────────────────────────────
#  DATABASE (opzionali)
# ───────────────────────────────────────────────────────────────────────────

# Default: localhost
DB_HOST=localhost

# Default: 3306
DB_PORT=3306


# ───────────────────────────────────────────────────────────────────────────
#  JWT, COOKIE E CORS
# ───────────────────────────────────────────────────────────────────────────

# Durata dei token. Default: 15m / 7d
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# SameSite dei cookie di sessione: `lax` | `strict` | `none`.
# `none` è necessario se frontend e backend stanno su domini diversi e FORZA
# `secure` (quindi richiede HTTPS). Default: lax
COOKIE_SAMESITE=lax

# Origini consentite da CORS, separate da virgola. I domini personalizzati
# VERIFICATI delle scuole sono ammessi automaticamente: qui vanno solo gli host
# "di piattaforma". Default: http://localhost:5173
CORS_ORIGIN=http://localhost:5173


# ───────────────────────────────────────────────────────────────────────────
#  IDENTITÀ DELLA PIATTAFORMA
#  (il software, uguale per tutti i tenant: le singole scuole hanno il proprio
#   branding nelle impostazioni, che sovrascrive sempre questo livello)
# ───────────────────────────────────────────────────────────────────────────

# Default: Piattaforma Didattica
PLATFORM_NAME=Piattaforma Didattica

# Default: Piattaforma di apprendimento per scuole e centri di formazione.
PLATFORM_DESCRIPTION=Piattaforma di apprendimento per scuole e centri di formazione.

# Versione esposta da GET /api/health. Default: 2.0.0
PLATFORM_VERSION=2.0.0

# URL pubblico del frontend: link nelle email, redirect OAuth, URL di ritorno
# di Stripe. Default: http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Indirizzo mittente delle email transazionali. Default: no-reply@localhost
EMAIL_FROM=no-reply@localhost

# Slug della scuola servita a chi non indica alcun tenant (deploy MONO-SCUOLA).
# Se non impostato e la piattaforma ha una sola scuola attiva, viene usata
# quella. Default: (nessuno)
DEFAULT_SCHOOL_SLUG=


# ───────────────────────────────────────────────────────────────────────────
#  SMTP (email transazionali)
# ───────────────────────────────────────────────────────────────────────────

# Default: smtp.gmail.com
EMAIL_HOST=smtp.gmail.com

# Default: 587
EMAIL_PORT=587

# `true` solo per la porta 465 (TLS implicito). Default: false
EMAIL_SECURE=false

EMAIL_USER=
EMAIL_PASS=


# ───────────────────────────────────────────────────────────────────────────
#  GOOGLE OAUTH 2.0 (opzionale)
#  Solo LOGIN/COLLEGAMENTO di account già esistenti: l'accesso alla
#  piattaforma è esclusivamente su invito, Google non crea mai un account.
#  Se CLIENT_ID o CLIENT_SECRET mancano, le route /google sono disabilitate
#  (warning all'avvio).
# ───────────────────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
GOOGLE_SUCCESS_REDIRECT=http://localhost:5173/dashboard

 
# ───────────────────────────────────────────────────────────────────────────
#  STRIPE — iscrizioni a pagamento (opzionale)
#
#  Modello: Stripe Connect con ADDEBITI DIRETTI. La scuola è l'esercente
#  (incassa sul proprio saldo e paga la commissione di Stripe); la piattaforma
#  trattiene `application_fee_amount` secondo la percentuale che l'admin fissa
#  per quella scuola.
#
#  Senza STRIPE_SECRET_KEY i pagamenti sono DISATTIVATI su tutta la piattaforma
#  (fail-closed: gli endpoint rispondono 503, nessuna scuola può attivarli).
# ───────────────────────────────────────────────────────────────────────────

# Chiave segreta dell'account PIATTAFORMA (sk_...). Default: (nessuna)
STRIPE_SECRET_KEY=

# ⚠️  SEGRETI DEI WEBHOOK — leggere, è la causa di errore più comune.
#
# Con gli addebiti diretti, `checkout.session.completed` viene recapitato
# all'endpoint CONNECT della piattaforma ("Listen to events on Connected
# accounts" nella dashboard Stripe), il cui segreto di firma è DIVERSO da
# quello di un endpoint "account". Registrare l'endpoint sbagliato fa fallire
# `constructEvent` con 400 su OGNI evento: nessuno studente verrebbe mai
# iscritto dopo il pagamento, e la causa è invisibile dai log applicativi.
#
# Il segreto dell'endpoint CONNECT è quello che serve al flusso di incasso:
STRIPE_WEBHOOK_SECRET_CONNECT=

# Segreto dell'endpoint "account" (eventi dell'account piattaforma). Utile se
# in futuro si ascoltano anche eventi non-Connect. Il backend prova entrambi i
# segreti, quindi in caso di dubbio si possono valorizzare tutti e due.
STRIPE_WEBHOOK_SECRET=

# Chiave pubblicabile (pk_...). Default: (nessuna)
STRIPE_PUBLISHABLE_KEY=

# Versione API bloccata (es. 2024-06-20). Consigliato fissarla: evita che un
# aggiornamento lato Stripe cambi il comportamento senza un rilascio.
STRIPE_API_VERSION=

# Valuta predefinita dei nuovi corsi acquistabili.
# Ammesse: EUR | USD | GBP | CHF. Default: EUR
PAGAMENTI_VALUTA_DEFAULT=EUR


# ───────────────────────────────────────────────────────────────────────────
#  UPLOAD DEI FILE
#
#  ⚠️  I limiti sono DUPLICATI lato frontend (VITE_UPLOAD_MAX_*): servono a
#      mostrare l'errore prima di sprecare la banda. Vanno tenuti allineati a
#      mano — se divergono, l'utente scopre il limite vero solo con un 413.
# ───────────────────────────────────────────────────────────────────────────

# Cartella radice dei file caricati. In produzione puntala a un volume
# persistente dedicato. Default: <backend>/uploads
UPLOAD_DIR=

# Default: 1024 (1 GB)
UPLOAD_MAX_VIDEO_MB=1024

# Default: 10
UPLOAD_MAX_IMMAGINE_MB=10

# Default: 100
UPLOAD_MAX_DOCUMENTO_MB=100


# ───────────────────────────────────────────────────────────────────────────
#  CACHE (in memoria, per-processo)
# ───────────────────────────────────────────────────────────────────────────

# TTL della cache delle impostazioni di scuola. Minimo 1000. Default: 30000
SETTINGS_CACHE_TTL_MS=30000

# TTL della cache di risposta di GET /api/config. Forzato nell'intervallo
# 60000–120000. Default: 90000
CONFIG_CACHE_TTL_MS=90000


# ───────────────────────────────────────────────────────────────────────────
#  NOTIFICHE EMAIL E JOB PERIODICI
# ───────────────────────────────────────────────────────────────────────────

# Interruttore generale del recapito email delle notifiche. Default: true
EMAIL_NOTIFICHE_ATTIVE=true

# Interruttore dei job periodici (digest, scadenze, retention). Mettilo a
# `false` su tutte le istanze tranne una in un deploy multi-processo: gli
# scheduler sono in-process e altrimenti il digest partirebbe N volte.
# Default: true
NOTIFICHE_SCHEDULER_ATTIVO=true

# Ogni quanto gira il job del digest, in minuti. Default: 240 (4 ore)
DIGEST_INTERVALLO_MINUTI=240

# Intervallo minimo tra due digest allo stesso utente, in ore. Default: 6
DIGEST_INTERVALLO_MINIMO_ORE=6

# Tetto di email di digest per utente al giorno. Default: 3
DIGEST_MAX_EMAIL_GIORNO=3

# Righe massime per sezione dentro un digest. Default: 20
DIGEST_MAX_RIGHE_SEZIONE=20

# Ogni quanto si scansionano le scadenze dei compiti, in minuti. Default: 720
SCADENZE_INTERVALLO_MINUTI=720

# Con quanto anticipo avvisare di un compito in scadenza, in ore. Default: 48
SCADENZA_COMPITO_PREAVVISO_ORE=48

# Ritardo prima della prima esecuzione dei job dopo l'avvio, in minuti.
# Lascia respirare il boot. Default: 1
SCHEDULER_RITARDO_INIZIALE_MINUTI=1


# ───────────────────────────────────────────────────────────────────────────
#  RETENTION (GDPR)
# ───────────────────────────────────────────────────────────────────────────

# Periodo di grazia tra la richiesta di cancellazione dell'account e
# l'eliminazione definitiva, in giorni. Default: 30
RETENTION_ACCOUNT_GIORNI=30

# Conservazione delle notifiche già inviate, in giorni. Default: 90
RETENTION_NOTIFICHE_GIORNI=90

# Ogni quanto gira il job di retention, in minuti. Default: 1440 (24 ore)
RETENTION_INTERVALLO_MINUTI=1440


# ───────────────────────────────────────────────────────────────────────────
#  DOCUMENTI LEGALI
#  La versione accettata viene scritta su `utenti.versione_termini` come prova
#  del consenso: cambiala quando cambia il testo dei documenti.
# ───────────────────────────────────────────────────────────────────────────

# Default: 2026-07-01
VERSIONE_TERMINI=2026-07-01

# Default: 2026-07-01
VERSIONE_CONSENSO_EMAIL=2026-07-01


# ───────────────────────────────────────────────────────────────────────────
#  TOKEN E INVITI
# ───────────────────────────────────────────────────────────────────────────

# Validità di un invito, in ore. Default: 168 (7 giorni)
INVITE_EXPIRES_HOURS=168

# Validità del link di reset password, in ore. Default: 1
RESET_PASSWORD_EXPIRES_HOURS=1


# ───────────────────────────────────────────────────────────────────────────
#  RATE LIMITING
#  Contatori in memoria, per-processo: in un deploy multi-istanza il limite
#  effettivo è N volte questi valori (serve uno store condiviso per unificarli).
# ───────────────────────────────────────────────────────────────────────────

# Finestra del limitatore globale, in ms. Default: 900000 (15 min)
RATE_LIMIT_WINDOW_MS=900000

# Richieste per IP nella finestra globale. Default: 1000
RATE_LIMIT_MAX=1000

# Tentativi di login falliti per IP in 15 min. Default: 5
LOGIN_RATE_LIMIT_MAX=5

# Default: 10
REGISTER_RATE_LIMIT_MAX=10

# Default: 60
REFRESH_RATE_LIMIT_MAX=60

# Default: 3
RESEND_VERIFICATION_RATE_LIMIT_MAX=3

# Default: 50
INVITE_RATE_LIMIT_MAX=50

# Default: 60
QUIZ_SUBMIT_RATE_LIMIT_MAX=60

# Default: 120
QUIZ_SCRITTURA_RATE_LIMIT_MAX=120

# Invii del form di contatto pubblico per IP. Default: 10
CONTACT_RATE_LIMIT_MAX=10

# Finestra del form di contatto, in ms. Default: 3600000 (1 ora)
CONTACT_RATE_LIMIT_WINDOW_MS=3600000


# ───────────────────────────────────────────────────────────────────────────
#  SEED (solo bootstrap iniziale)
#  Usate una tantum dagli script `npm run seed:*`. Dopo il primo avvio possono
#  essere rimosse: tenere una password in chiaro nel .env non serve a nulla.
# ───────────────────────────────────────────────────────────────────────────

# Obbligatorie per `npm run seed:admin`.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NOME=
ADMIN_COGNOME=

# Usate da `npm run seed:scuola` per creare il primo tenant.
SEED_SCUOLA_NOME=
SEED_SCUOLA_SLUG=
SEED_SCUOLA_EMAIL=
